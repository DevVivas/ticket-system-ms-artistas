{
  "title": "MS-Artistas — Observabilidad",
  "uid": "ms-artistas-overview",
  "tags": ["ticket-system", "ms-artistas", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "constant",
        "label": "Aplicación",
        "query": "ms-artistas",
        "current": { "text": "ms-artistas", "value": "ms-artistas" },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Estado del Servicio",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "up{application=\"$application\"}",
          "legendFormat": "up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "process_uptime_seconds{application=\"$application\"}", "legendFormat": "uptime" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "Tasa de Requests HTTP (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\"}[1m])) by (uri, method)",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "title": "Tasa de Errores HTTP (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$application\",status=~\"5..\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 5,
      "title": "Latencia P95 por Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[5m])) by (le, uri))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "Uso de Memoria JVM (Heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"$application\",area=\"heap\"}",
          "legendFormat": "usado - {{id}}"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"$application\",area=\"heap\"}",
          "legendFormat": "máximo - {{id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 7,
      "title": "CPU del Proceso (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"$application\"} * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    },
    {
      "id": 8,
      "title": "Conexiones HikariCP (Pool MySQL)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"$application\"}",
          "legendFormat": "activas"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"$application\"}",
          "legendFormat": "inactivas"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"$application\"}",
          "legendFormat": "en espera"
        }
      ]
    },
    {
      "id": 9,
      "title": "Hilos JVM",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"$application\"}",
          "legendFormat": "vivos"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"$application\"}",
          "legendFormat": "daemon"
        }
      ]
    },
    {
      "id": 10,
      "title": "Pausas de Garbage Collector",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"$application\"}[5m])",
          "legendFormat": "{{action}} - {{cause}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11,
      "title": "Top Endpoints más Lentos (P99)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"$application\"}[5m])) by (le, uri)))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12,
      "title": "Logs en vivo — ms-artistas (Loki)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessages": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service=\"ms-artistas\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Tasa de Logs por Nivel (ERROR / WARN / INFO)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 42 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"ms-artistas\"} | json | level=\"ERROR\" [1m]))",
          "legendFormat": "ERROR"
        },
        {
          "expr": "sum(count_over_time({service=\"ms-artistas\"} | json | level=\"WARN\" [1m]))",
          "legendFormat": "WARN"
        },
        {
          "expr": "sum(count_over_time({service=\"ms-artistas\"} | json | level=\"INFO\" [1m]))",
          "legendFormat": "INFO"
        }
      ]
    }
  ]
}
