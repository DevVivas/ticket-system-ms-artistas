<?xml version="1.0" encoding="UTF-8"?>
<!--
  ─────────────────────────────────────────────────────────────────────────
  Configuración de Logback — ms-artistas
  Salida dual:
    - CONSOLE: formato legible para desarrollo local
    - JSON:    formato estructurado (stdout) consumido por Promtail -> Loki
  El perfil activo se controla con la variable de entorno LOG_FORMAT
  (valores: "plain" | "json", por defecto "json" para contenedores)
  ─────────────────────────────────────────────────────────────────────────
-->
<configuration>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="ms-artistas"/>
    <property name="LOG_FORMAT" value="${LOG_FORMAT:-json}"/>

    <!-- Salida legible para consola (uso local) -->
    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Salida JSON estructurada (uso en contenedores -> Promtail -> Loki) -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"application":"${appName}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <message>message</message>
                <logger>logger_name</logger>
                <thread>thread_name</thread>
                <level>level</level>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
        </encoder>
    </appender>

    <springProfile name="docker,prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

    <springProfile name="default,local,test">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </root>
    </springProfile>

    <!-- Nivel de detalle propio del microservicio -->
    <logger name="com.ticket_system" level="DEBUG"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.hibernate.SQL" level="INFO"/>

</configuration>
